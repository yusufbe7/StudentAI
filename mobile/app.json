{
  "expo": {
    "name": "StudentAI",
    "slug": "studentai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "studentai",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studentai.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Ilovaga tez va xavfsiz kirish uchun Face ID ishlatiladi."
      }
    },
    "android": {
      "package": "com.studentai.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#6c5ce7"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://YOUR-SERVER-URL.up.railway.app"
    }
  }
}
